#!/bin/zsh
set -e

function git_main_branch() {
	command git rev-parse --git-dir &>/dev/null || return

	local remote ref

	for ref in refs/{heads,remotes/{origin,upstream}}/{main,trunk,mainline,default,stable,master}; do
		if command git show-ref -q --verify $ref; then
			echo ${ref:t}
			return 0
		fi
	done

	for remote in origin upstream; do
		ref=$(command git rev-parse --abbrev-ref $remote/HEAD 2>/dev/null)
		if [[ $ref == $remote/* ]]; then
			echo ${ref#"$remote/"}; return 0
		fi
	done

	echo master
	return 1
}

interactive=""
abort=false
push=false
while getopts "iap" opt; do
	case $opt in
		i) interactive="-i" ;;
		a) abort=true ;;
		p) push=true ;;
		*) echo "usage: gsrb [-i] [-a] [-p] [base]" >&2; exit 1 ;;
	esac
done
shift $((OPTIND - 1))

gitdir=$(git rev-parse --git-dir)
statefile="$gitdir/gsrb-state"

if $abort; then
	if [ -d "$gitdir/rebase-merge" ] || [ -d "$gitdir/rebase-apply" ]; then
		git rebase --abort
	fi
	rm -f "$statefile"
	echo "stack rebase aborted"
	exit 0
fi

if [ -d "$gitdir/rebase-merge" ] || [ -d "$gitdir/rebase-apply" ]; then
	echo "rebase in progress — run 'git rebase --continue' or 'gsrb -a' to abort" >&2
	exit 1
fi

typeset -A old_tips
remaining=()
rebased=()

if [ -f "$statefile" ]; then
	while IFS=' ' read -r key val; do
		case "$key" in
			current) current="$val" ;;
			prev) prev="$val" ;;
			prev_old) prev_old="$val" ;;
			*) remaining+=("$key"); old_tips[$key]="$val" ;;
		esac
	done < "$statefile"
	echo "resuming stack: ${remaining[*]}"
else
	if [ -n "$1" ]; then
		main="$1"
	else
		main=$(git_main_branch)
	fi

	current=$(git branch --show-current)
	merge_base=$(git merge-base HEAD "$main")

	# collect branches in stack order (closest to main first)
	branches=()
	for commit in $(git rev-list --reverse "$merge_base"..HEAD); do
		for b in $(git branch --points-at "$commit" --format='%(refname:short)'); do
			case "$b" in $main) continue ;; esac
			branches+=("$b")
		done
	done

	if (( ${#branches} == 0 )); then
		echo "no branches found in stack"
		exit 0
	fi

	echo "stack: ${branches[*]}"

	for b in "${branches[@]}"; do
		old_tips[$b]=$(git rev-parse "$b")
	done

	remaining=("${branches[@]}")
	prev="$main"
	prev_old="$merge_base"
fi

while (( ${#remaining} > 0 )); do
	b="${remaining[1]}"
	old="${old_tips[$b]}"
	remaining=("${remaining[@]:1}")

	# save state for recovery: what's needed after b completes
	{
		echo "current $current"
		echo "prev $b"
		echo "prev_old $old"
		for r in "${remaining[@]}"; do
			echo "$r ${old_tips[$r]}"
		done
	} > "$statefile"

	echo "rebasing $b onto $prev"
	git rebase $interactive --onto "$prev" "$prev_old" "$b"

	if [ -d "$gitdir/rebase-merge" ] || [ -d "$gitdir/rebase-apply" ]; then
		echo "rebase paused — complete it, then re-run gsrb" >&2
		exit 1
	fi

	rebased+=("$b")
	prev_old="$old"
	prev="$b"
done

rm -f "$statefile"

if $push && (( ${#rebased} > 0 )); then
	echo "pushing ${#rebased} branches"
	git push --force-with-lease origin "${rebased[@]}"
fi

if [ -n "$current" ] && [ "$current" != "$b" ]; then
	git checkout "$current"
fi
