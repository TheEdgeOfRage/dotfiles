// vim: set noet ft=chezmoitmpl.jsonc:
{{- $cpuThreads := (output "sh" "-c" "lscpu --online --parse | grep --invert-match '^#' | wc --lines") | trim | atoi | add -1 | int }}
{
	"layer": "top",
	"position": "bottom",
	"reload_style_on_change": true,
	"modules-right": [
		"custom/arrow_left_end_alt",
		"custom/tailscale",
		"custom/arrow_left_alt",
		"network",
		"custom/arrow_left",
		"temperature",
		"custom/arrow_left_alt",
		"cpu",
		"custom/arrow_left",
		"memory",
		"custom/arrow_left_alt",
		"tray"
	],
	"power-profiles-daemon": {
		"format": "{icon}",
		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
		"tooltip": true,
		"format-icons": {
			"default": "",
			"performance": "",
			"balanced": "",
			"power-saver": ""
		}
	},
	"cpu": {
		"interval": 1,
		"tooltip": false,
		"format": "{{- range $i := splitList " " (seq 0 $cpuThreads) -}}{icon{{ $i }}}{{- end -}}",
		"format-alt": "Ôčõ  {usage}% ({load})",
		"format-icons": [
			"<span color='#98971a'>‚ĖĀ</span>", // green
			"<span color='#98971a'>‚Ėā</span>", // green
			"<span color='#d79921'>‚ĖÉ</span>", // yellow
			"<span color='#d79921'>‚ĖĄ</span>", // yellow
			"<span color='#d65d0e'>‚ĖÖ</span>", // orange
			"<span color='#d65d0e'>‚ĖÜ</span>", // orange
			"<span color='#cc241d'>‚Ėá</span>", // red
			"<span color='#cc241d'>‚Ėą</span>" // red
		]
	},
	"memory": {
		"interval": 5,
		"format": "ÔĒł {used:0.1f}G/{total:0.1f}G",
		"states": {
			"warning": 70,
			"critical": 90
		},
		"tooltip": false
	},
	"temperature": {
		"critical-threshold": 90,
		"interval": 1,
		"hwmon-path-abs": "/sys/devices/{{ .waybar.bottom.cpu_temp_path }}/hwmon",
		"input-filename": "{{ .waybar.bottom.cpu_temp_filename }}",
		"format": "{icon} {temperatureC}¬įC",
		"format-icons": [
			"Ôčč",
			"Ôčä",
			"ÔčČ",
			"Ôčą",
			"Ôčá"
		],
		"tooltip": false
	},
	"tray": {
		"icon-size": 18
		//"spacing": 10
	},
	"network": {
		"interval": 1,
		"format-wifi": "Ôáę {essid} ({signalStrength}%) ÔĄá{bandwidthDownBytes} ÔĄÜ{bandwidthUpBytes}",
		"format-ethernet": "ÓĹĄ ÔĄá{bandwidthDownBytes} ÔĄÜ{bandwidthUpBytes}",
		"format": "ÓĹĄ ÔĄá{bandwidthDownBytes} ÔĄÜ{bandwidthUpBytes}",
		"format-disconnected": "ůį≤ú",
		"format-alt": "ůį©† {ipaddr}/{cidr}",
		"tooltip": false
	},
	"custom/tailscale": {
		"exec": "tailscale status --json 2>/dev/null | jq -r 'if .BackendState == \"Running\" then \" ůįĖā \" else \" ůį≤ú \" end'",
		"interval": 5,
		"tooltip": false
	},
	"custom/arrow_left": {
		"format": "Óā≤",
		"tooltip": false
	},
	"custom/arrow_left_alt": {
		"format": "Óā≤",
		"tooltip": false
	},
	"custom/arrow_left_end": {
		"format": "Óā≤",
		"tooltip": false
	},
	"custom/arrow_left_end_alt": {
