	"mpris": {
		"interval": 5,
		"format": "{player_icon} {dynamic}",
		"format-paused": "{status_icon} {dynamic}",
		"dynamic-order": [
			"artist",
			"title",
			"position",
			"length"
		],
		"player-icons": {
			"default": "ΎΒΜ"
		},
		"status-icons": {
			"paused": "ΎΒΝ"
		},
		"player": "Supersonic"
	},
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": ["≤░Δη","≤░Δθ","≤░Δι"]
	},
	"battery": {
		"interval": 60,
		"states": {
			"warning": 30,
			"critical": 10
		},
		"format-time": "{H}:{M:02}",
		"format": "{icon} {capacity}% ({time})",
		"format-charging": "ΎΔπ {capacity}% ({time})",
		"format-charging-full": "ΎΔπ {capacity}%",
		"format-full": "{icon} {capacity}%",
		"format-alt": "{icon} {power}W",
		"format-icons": [
			"ΎΚΕ",
			"ΎΚΔ",
			"ΎΚΓ",
			"ΎΚΒ",
			"ΎΚΑ"
		],
		"tooltip": false
	},
	"clock#time": {
		"interval": 60,
		"format": "{:%H:%M}",
		"tooltip": true,
		"tooltip-format": "{:%H:%M:%S}"
	},
	"clock#date": {
		"interval": 60,
		"format": "{:%a %d}",
		"tooltip": true,
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode": "month",
			"mode-mon-col": 3,
			"weeks-pos": "",
			"on-scroll": 1,
			"format": {
				"months": "<span color='#ebdbb2'><b>{}</b></span>",
				"days": "<span color='#ebdbb2'><b>{}</b></span>",
				"weekdays": "<span color='#d79921'><b>{}</b></span>",
				"today": "<span color='#cc241d'><b><u>{}</u></b></span>"
			}
		},
		"actions": {
			"on-click-right": "mode",
			"on-click-middle": "shift_reset",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
	},
	"hyprland/language": {
		"format": "ΎΕε {}",
		"keyboard-name": "at-translated-set-2-keyboard",
		"tooltip": false,
		"on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next",
		"format-en": "EN",
		"format-sr(latinunicode)": "SR",
		"format-sr": "SR",
		"format-de": "DE"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"format-bluetooth": "{icon}ΎΛΦ {volume}%",
		"format-muted": "Ό╗ρ",
		"format-icons": {
			"headphone": "ΎΑξ",
			"hands-free": "ΎΨΡ",
			"headset": "ΎΨΡ",
			"phone": "ΎΓΧ",
			"portable": "ΎΓΧ",
			"car": "ΎΗ╣",
			"default": [
				"ΎΑο",
				"ΎΑπ",
				"ΎΑρ"
			]
		},
		"scroll-step": 2,
		"tooltip": true,
		"tooltip-format": "{desc}",
		"on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
	},
	"pulseaudio#mic": {
		"format": "{format_source}",
		"format-source": "ΎΕ░ {volume}%",
		"format-source-muted": "ΎΕ▒",
		"tooltip": false,
		"on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
		"on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +2%",
		"on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -2%"
	},
	"custom/crypto": {
		"format": "{}",
		"interval": 60,
		"return-type": "json",
		"exec": "waybar-crypto",
		"exec-if": "ping pro-api.coinmarketcap.com -c1"
	},
	"custom/arrow_left": {
		"format": "ΌΓ▓",
		"tooltip": false
	},
	"custom/arrow_left_alt": {
		"format": "ΌΓ▓",
		"tooltip": false
	},
	"custom/arrow_left_end": {
		"format": "ΌΓ▓",
		"tooltip": false
	},
	"custom/arrow_left_end_alt": {
		"format": "ΌΓ▓",
		"tooltip": false
	}
