{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "*sudo*": "deny",
      "*terraform apply*": "deny"
    },
    "external_directory": {
      "/home/pavle/dev/*": "allow",
      "/home/pavle/.local/share/opencode/*": "allow",
      "/home/pavle/.cache/*": "allow",
      "/home/pavle/.cargo/*": "allow",
      "/home/pavle/.gradle/*": "allow",
      "/tmp/opencode/*": "allow"
    },
    "webfetch": "ask",
    "websearch": "allow",
    "codesearch": "allow",
    "doom_loop": "ask"
  },
  "plugin": [
    "@tarquinen/opencode-dcp@v3.1.13",
    "/home/pavle/dev/opencode/policy-engine/src/index.ts"
  ],
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://cuprum.wg:8080/v1"
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B (local)",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "grafana prod": {
      "enabled": false,
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "https://grafana.prod.internal.dunetech.io/",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{file:~/hfs/mcp/grafana-prod-token}"
      }
    },
    "grafana dev": {
      "enabled": false,
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "https://grafana.dev.internal.dunetech.io/",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{file:~/hfs/mcp/grafana-dev-token}"
      }
    },
    "dune": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.dune.com/mcp/v1",
      "oauth": {}
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "sentry": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    },
    "metabase": {
      "type": "remote",
      "url": "https://metabase.prod.internal.dunetech.io/api/mcp",
      "enabled": false
    },
    "trino-insights": {
      "type": "remote",
      "url": "http://prod-trino-insights-mcp.ayu-decibel.ts.net",
      "headers": {
        "Authorization": "Bearer {env:DUNE_TRINO_INSIGHTS_TOKEN}"
      },
      "enabled": false
    }
  },
  "formatter": {
    "clang-format": {
      "disabled": true
    }
  },
  "instructions": [
    "/home/pavle/.cache/dune-sietch/sietch/bundles/base/instructions/dune-base.md"
  ]
}
