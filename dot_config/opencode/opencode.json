{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "*sudo*": "deny",
      "*terraform apply*": "deny"
    },
    "external_directory": {
      "/home/pavle/dev/*": "allow",
      "/home/pavle/.local/share/opencode/*": "allow"
    },
    "webfetch": "ask",
    "websearch": "allow",
    "codesearch": "allow",
    "doom_loop": "ask"
  },
  "plugin": [
    "@tarquinen/opencode-dcp@v3.1.13",
    "/home/pavle/dev/opencode/policy-engine/src/index.ts"
  ],
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://cuprum.wg:8080/v1"
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6 27B (local)",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "Sentry": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    },
    "Grafana prod": {
      "enabled": false,
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "https://grafana.prod.internal.dunetech.io/",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{file:~/hfs/mcp/grafana-prod-token}"
      }
    },
    "Grafana dev": {
      "enabled": false,
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "https://grafana.dev.internal.dunetech.io/",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{file:~/hfs/mcp/grafana-dev-token}"
      }
    },
    "GitHub": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "{file:~/hfs/mcp/github}"
      }
    },
    "dune": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.dune.com/mcp/v1",
      "oauth": {}
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    },
    "dbt": {
      "type": "local",
      "command": ["uvx", "dbt-mcp"],
      "environment": {
        "DBT_HOST": "nd058.us1.dbt.com",
        "DBT_ACCOUNT_ID": "58579",
        "DBT_PROJECT_IDS": "259299,335774,370651,372284,372518",
        "DBT_TOKEN": "{env:DBT_TOKEN}"
      },
      "enabled": false
    },
    "metabase": {
      "type": "remote",
      "url": "https://metabase.prod.internal.dunetech.io/api/mcp",
      "enabled": false
    }
  },
  "formatter": {
    "clang-format": {
      "disabled": true
    }
  },
  "model": "openai/gpt-5.6-terra",
  "small_model": "openai/gpt-5.6-luna",
  "enabled_providers": ["openai", "anthropic", "vercel"],
  "disabled_providers": ["amazon-bedrock"],
  "instructions": [
    "/home/pavle/.cache/dune-sietch/sietch/bundles/base/instructions/dune-base.md"
  ]
}
